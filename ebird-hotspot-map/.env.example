# Local dev convenience only — DO NOT set this on your deployed host.
# Production users bring their own eBird API token via the in-app Settings.
# Setting VITE_EBIRD_TOKEN in prod would bake your key into the public bundle.
#
# To skip pasting your token into Settings every time you wipe localStorage,
# copy this file to .env.local and fill in your own value below.
# Request a token at https://ebird.org/api/keygen
VITE_EBIRD_TOKEN=your_ebird_api_token_here
